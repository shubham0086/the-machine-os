# Session breadcrumbs belong in the main project's docs/sessions/, never here.
# The SessionEnd hook writes docs/sessions/ relative to cwd; ignore it so a session
# run with this repo as cwd can't pollute the public handbook.
docs/

# Secrets & local env
.env
.env.*
!.env.example

# Dependencies / build / OS noise
node_modules/
.DS_Store
*.log
